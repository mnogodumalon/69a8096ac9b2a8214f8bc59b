        "Use null for any field that cannot be determined.",
        `Schema:\n${schemaDescription}`,
      ].join("\n"),
    },
    {
      role: "user",
      content: [
        { type: "text", text: "Extract the data from this image." },
        { type: "image_url", image_url: { url: imageDataUri } },
      ],
    },
  ]);
}

